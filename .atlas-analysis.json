  "keyFeatures": [
    "Visual workflow builder with drag-and-drop node editor",
    "Multiple trigger types: Manual, Webhook, and Cron scheduling",
    "AI integrations with OpenAI, Anthropic, and Gemini",
    "Integration nodes for GitHub, Notion, Slack, Discord",
    "Real-time execution streaming via WebSockets",
    "Encrypted credential storage with AES-256-GCM",
    "Distributed job processing with BullMQ and Redis",
    "Self-hostable with Docker or manual deployment",
    "Conditional logic and data transformation nodes",
    "Full monorepo architecture with Next.js frontend"
  ],
  "publicApiSurface": [
    "POST /api/webhooks/[workflowId]/[nodeId] - Webhook ingestion endpoint",
    "GET /api/executions/[runId]/stream - Server-sent events for execution streaming",
    "GET /api/executions/[runId]/ws-token - WebSocket authentication token",
    "POST /api/trpc/workflow.create - Create new workflow",
    "POST /api/trpc/workflow.update - Update workflow configuration",
    "POST /api/trpc/workflow.delete - Delete workflow",
    "POST /api/trpc/execution.run - Execute workflow manually",
    "GET /api/trpc/execution.list - List workflow runs",
    "POST /api/trpc/credentials.create - Store encrypted credentials",
    "GET /api/trpc/credentials.list - List user credentials",
    "WebSocket ws://localhost:3101 - Real-time execution events"
  ]
}
